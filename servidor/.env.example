# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True

# LLM Configuration (legacy fallback — client now selects provider/model dynamically)
OPENAI_API_KEY=sk-your-openai-api-key-here
GOOGLE_API_KEY=AIza...
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Embeddings: "openai", "gemini", or "local" (auto-detect if empty)
# gemini models: gemini-embedding-2-preview, embedding-001
# openai models: text-embedding-3-small, text-embedding-3-large
# local models: BAAI/bge-small-en-v1.5, BAAI/bge-base-en-v1.5
EMBEDDINGS_PROVIDER=
EMBEDDINGS_MODEL=

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000
